<Window x:Class="MTtool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge Tactics Tool" Height="900" Width="1300"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧主区域 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部控制栏 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="已选卡牌：" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock x:Name="SelectedCountText" Text="{Binding SelectedCount, StringFormat={}{0}/6}" 
                           FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                <Button x:Name="ResetAllButton" Content="重置所有" Margin="20,0,5,0" Padding="8,3" Click="ResetAllButton_Click"/>
                <Button x:Name="ClearSelectedButton" Content="清空已选" Margin="5,0" Padding="8,3" Click="ClearSelectedButton_Click"/>
            </StackPanel>

            <!-- 表格区域 -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Border BorderBrush="Gray" BorderThickness="1">
                    <Grid x:Name="TableGrid" Background="WhiteSmoke"/>
                </Border>
            </ScrollViewer>

            <!-- 额外羁绊组件（可折叠） -->
            <Expander Grid.Row="2" Header="{Binding ExtraTraitsHeader}" Margin="0,10,0,5" IsExpanded="False">
                <Expander.HeaderTemplate>
                    <DataTemplate>
                        <WrapPanel>
                            <TextBlock Text="额外羁绊 " FontWeight="Bold" Margin="0,0,10,0" />
                            <ItemsControl ItemsSource="{Binding DataContext.ExtraTraitsIcons, RelativeSource={RelativeSource AncestorType=Window}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="Blue" BorderThickness="1" CornerRadius="4" Margin="3,0,3,0" Padding="2,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Image}" Width="20" Height="20" Margin="2" />
                                                <TextBlock Text="{Binding Count}" VerticalAlignment="Center" Margin="2,0,2,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </DataTemplate>
                </Expander.HeaderTemplate>
                <StackPanel Margin="5">
                    <ItemsControl ItemsSource="{Binding ExtraTraits1List}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Margin="5,2" Padding="5,2"
                                        Background="Transparent">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.IncrementExtraTraitCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                        <MouseBinding MouseAction="RightClick" Command="{Binding DataContext.ResetExtraTraitCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Image}" Width="30" Height="30" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding Count}" VerticalAlignment="Center" FontWeight="Bold" MinWidth="20" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding ExtraTraits2List}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Margin="5,2" Padding="5,2"
                                        Background="Transparent">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.IncrementExtraTraitCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                        <MouseBinding MouseAction="RightClick" Command="{Binding DataContext.ResetExtraTraitCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Image}" Width="30" Height="30" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding Count}" VerticalAlignment="Center" FontWeight="Bold" MinWidth="20" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- 已激活羁绊面板 -->
            <Border Grid.Row="3" Background="#F0F0F0" BorderBrush="LightGray" BorderThickness="1" 
                    Margin="0,5,0,0" Padding="5">
                <StackPanel>
                    <TextBlock Text="已激活羁绊" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding ActiveTraits}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Green" BorderThickness="1" CornerRadius="4" Margin="5,2" Padding="5,2">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding TraitImage}" Width="24" Height="24" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 右侧推荐面板（固定宽度，带滚动条） -->
        <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="LightGray" BorderThickness="1,0,0,0" Margin="20,0,0,0">
            <StackPanel Margin="5">
                <TextBlock Text="实时推荐阵容" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <ScrollViewer MaxHeight="700" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Recommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,0,0,10" Padding="0,0,0,10">
                                    <StackPanel>
                                        <!-- 卡牌图片行 -->
                                        <WrapPanel>
                                            <ItemsControl ItemsSource="{Binding Cards}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Margin="2" Background="White">
                                                            <Image Source="{Binding ImageSource}" Stretch="Uniform" Width="40" Height="40">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Opacity" Value="1.0" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                                                                <Setter Property="Opacity" Value="0.5" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </WrapPanel>
                                        <!-- 羁绊摘要行 -->
                                        <WrapPanel Margin="0,5,0,0">
                                            <ItemsControl ItemsSource="{Binding ActivatedTraits}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="5,0,10,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Image Source="{Binding TraitImage}" Width="20" Height="20" Margin="0,0,3,0"/>
                                                                <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </WrapPanel>
                                        <!-- 分数行 -->
                                        <TextBlock Text="{Binding ScoreDisplay}" FontWeight="Bold" Margin="0,5,0,0" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="{Binding CalculationTimeText}" FontStyle="Italic" FontSize="11" Foreground="Gray" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>